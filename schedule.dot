digraph schedule {
    rankdir=TB;
    node [shape=box, style=filled, fillcolor=lightyellow];

    subgraph cluster_setup_PreSetup {
        label="Setup: PreSetup";
        style=filled; fillcolor=lightblue;
        setup_0 [label="comm::comm_read_input"];
    }

    subgraph cluster_setup_Setup {
        label="Setup: Setup";
        style=filled; fillcolor=lightblue;
        setup_1 [label="domain::domain_read_input"];
        setup_2 [label="mddem_neighbor::neighbor_read_input"];
        setup_3 [label="run::run_read_input"];
        setup_4 [label="dem_atom_insert::dem_insert_atoms"];
    }

    subgraph cluster_setup_PostSetup {
        label="Setup: PostSetup";
        style=filled; fillcolor=lightblue;
        setup_5 [label="comm::comm_setup"];
        setup_6 [label="mddem_neighbor::neighbor_setup"];
        setup_7 [label="mddem_print::setup_thermo"];
        setup_8 [label="mddem_print::read_restart"];
        setup_9 [label="dem_atom_insert::calculate_delta_time"];
    }

    subgraph cluster_InitialIntegration {
        label="InitialIntegration";
        style=filled; fillcolor=lightyellow;
        update_0 [label="mddem_verlet::initial_integration"];
        update_1 [label="rotational::initial_rotation"];
    }

    subgraph cluster_PostInitialIntegration {
        label="PostInitialIntegration";
        style=filled; fillcolor=lightyellow;
        update_2 [label="atom::remove_ghost_atoms"];
        update_3 [label="atom::zero_all_forces"];
    }

    subgraph cluster_PreExchange {
        label="PreExchange";
        style=filled; fillcolor=lightyellow;
        update_4 [label="domain::pbc"];
        update_5 [label="mddem_print::print_granular_temperature"];
    }

    subgraph cluster_Exchange {
        label="Exchange";
        style=filled; fillcolor=lightyellow;
        update_6 [label="comm::exchange"];
    }

    subgraph cluster_PreNeighbor {
        label="PreNeighbor";
        style=filled; fillcolor=lightyellow;
        update_7 [label="comm::borders"];
    }

    subgraph cluster_Neighbor {
        label="Neighbor";
        style=filled; fillcolor=lightyellow;
        update_8 [label="mddem_neighbor::sweep_and_prune_neighbor_list"];
    }

    subgraph cluster_Force {
        label="Force";
        style=filled; fillcolor=lightyellow;
        update_9 [label="normal::hertz_normal_force\n[hertz_normal]"];
        update_10 [label="tangential::mindlin_tangential_force\n[mindlin_tangential]"];
    }

    subgraph cluster_PostForce {
        label="PostForce";
        style=filled; fillcolor=lightyellow;
        update_11 [label="comm::reverse_send_force"];
    }

    subgraph cluster_FinalIntegration {
        label="FinalIntegration";
        style=filled; fillcolor=lightyellow;
        update_12 [label="mddem_verlet::final_integration"];
        update_13 [label="rotational::final_rotation"];
    }

    subgraph cluster_PostFinalIntegration {
        label="PostFinalIntegration";
        style=filled; fillcolor=lightyellow;
        update_14 [label="run::update_cycle"];
        update_15 [label="mddem_print::print_vtp"];
        update_16 [label="mddem_print::print_thermo"];
        update_17 [label="mddem_print::dump_atoms"];
        update_18 [label="mddem_print::write_restart"];
    }

    update_9 -> update_10 [color=red, style=dashed, label="after"];
    update_1 -> update_2 [color=blue, style=bold];
    update_3 -> update_4 [color=blue, style=bold];
    update_5 -> update_6 [color=blue, style=bold];
    update_6 -> update_7 [color=blue, style=bold];
    update_7 -> update_8 [color=blue, style=bold];
    update_8 -> update_9 [color=blue, style=bold];
    update_10 -> update_11 [color=blue, style=bold];
    update_11 -> update_12 [color=blue, style=bold];
    update_13 -> update_14 [color=blue, style=bold];
    update_18 -> update_0 [color=green, style=bold, label="run loop", constraint=false];
    setup_9 -> update_0 [color=blue, style=bold, label="start run"];
}
